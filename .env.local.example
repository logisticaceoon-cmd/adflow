# ─── SUPABASE ───────────────────────────────────────
# Obtenés estos valores en: supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── ANTHROPIC (Claude IA) ───────────────────────────
# Obtenés en: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── RESEND (emails) ────────────────────────────────
# Obtenés en: resend.com → API Keys
RESEND_API_KEY=re_...

# ─── META / FACEBOOK ────────────────────────────────
# Obtenés en: developers.facebook.com → tu app → Configuración básica
FB_APP_ID=123456789012345
FB_APP_SECRET=abcdef1234567890abcdef1234567890

# ─── APP ────────────────────────────────────────────
# En desarrollo usa localhost, en producción tu dominio real
NEXT_PUBLIC_APP_URL=http://localhost:3000
